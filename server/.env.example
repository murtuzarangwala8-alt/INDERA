# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/indera-jewelry
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/indera-jewelry

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_CURRENCY=eur

# ── Email (SMTP) ──────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=INDÉRA <noreply@indera.it>
ADMIN_NOTIFY_EMAIL=admin@indera.it

# ── Frontend URL ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Admin credentials (REQUIRED — no defaults in code) ────────
# Use a strong, unique password. Never commit real values.
ADMIN_EMAIL=admin@indera.it
ADMIN_PASSWORD=YourStrongAdminPassword123!
ADMIN_API_KEY=generate-a-long-random-string-here

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=generate-a-long-random-secret-here
JWT_EXPIRES_IN=24h

# ── Twilio (WhatsApp OTP) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Set to false to skip WhatsApp OTP during local development
REQUIRE_WHATSAPP_OTP=false

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

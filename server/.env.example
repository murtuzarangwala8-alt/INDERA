# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/chronolux-watches
# Or use MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/chronolux-watches

# Stripe Payment Keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Email Configuration (for order confirmations)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=ChronoLux Watches <noreply@chronolux.com>

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Admin notification email (receives contact form + return request alerts)
# Defaults to EMAIL_FROM if not set
ADMIN_NOTIFY_EMAIL=admin@indera.it
